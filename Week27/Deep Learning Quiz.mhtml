<div class=3D"orb orb2"></div>

<div class=3D"wrapper">

  <header>
    <div class=3D"badge">Deep Learning =C2=B7 Knowledge Check</div>
    <h1>Optimizers, BatchNorm<br>&amp; Dropout</h1>
    <p class=3D"subtitle">10 questions =C2=B7 concepts from all sessions</p=
>
  </header>

  <!-- Progress -->
  <div class=3D"progress-wrap">
    <div class=3D"progress-meta">
      <span id=3D"prog-label">Question 10 of 10</span>
