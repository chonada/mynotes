t-8"></div><div class=3D"dot correct" id=3D"dot-9"></div></div>
  </div>

  <!-- Quiz -->
  <div id=3D"quiz-area" style=3D"display: block;">
    <div class=3D"q-card" id=3D"q-card">
      <div class=3D"q-number">Q10 / 10</div>
      <span class=3D"q-topic">Dropout</span>
      <div class=3D"q-text">Your model has train accuracy 95% and validatio=
n accuracy 65% after 20 epochs. You're using BatchNorm with no Dropout. Wha=
t is the BEST first action?</div>
     =20
      <div class=3D"options">
    <div class=3D"opt locked" id=3D"opt-0">
      <div class=3D"opt-key">A</div>
      <div class=3D"opt-text">Increase the learning rate to converge faster=
</div>
    </div>
 =20
    <div class=3D"opt locked" id=3D"opt-1">
      <div class=3D"opt-key">B</div>
      <div class=3D"opt-text">Add more layers to increase model capacity</d=
iv>
    </div>
 =20
    <div class=3D"opt locked correct" id=3D"opt-2">
      <div class=3D"opt-key">C</div>
      <div class=3D"opt-text">Add Dropout (p=E2=89=880.4=E2=80=930.5) after=
 FC layers to regularise</div>
    </div>
 =20
    <div class=3D"opt locked" id=3D"opt-3">
      <div class=3D"opt-key">D</div>
      <div class=3D"opt-text">Switch from BatchNorm to LayerNorm</div>
    </div>
  </div>
      <div class=3D"explanation show correct-exp" id=3D"exp"><span class=3D=
"exp-label">=E2=9C=93 Correct</span>A 30% train/val gap is classic overfitt=
ing. Adding Dropout (p=3D0.4=E2=80=930.5) after the dense layers prevents n=
eurons from co-adapting and forces the network to learn more robust feature=
s. BatchNorm helps slightly but isn't enough alone. Increasing LR or capaci=
ty would worsen overfitting. Changing norm type wouldn't address the root c=
ause.</div>
      <button class=3D"btn-next show" id=3D"btn-next">
        <span>See Results =E2=86=92</span>
      </button>
    </div>
  </div>

